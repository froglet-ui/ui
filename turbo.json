{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "packages/froglet-ui/dist/**",
        "apps/storybook/storybook-static/**"
      ]
    },
    "clean": {
      "cache": false,
      "dependsOn": ["^clean"]
    },
    "clean:build": {
      "cache": false,
      "dependsOn": ["^clean:build"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": []
    }
  }
}
