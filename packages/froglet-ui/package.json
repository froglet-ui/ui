{
  "name": "@froglet/ui",
  "version": "0.0.0",
  "description": "An open source, accessible React component library with full CSS custom property theming.",
  "keywords": [
    "react",
    "component-library",
    "ui",
    "css-custom-properties",
    "accessibility",
    "wcag",
    "typescript"
  ],
  "homepage": "https://froglet.io",
  "bugs": {
    "url": "https://github.com/froglet-ui/ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/froglet-ui/ui.git"
  },
  "license": "MIT",
  "author": "J. Ryan Conklin",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json",
    "./styles": "./dist/index.css"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf .turbo dist node_modules",
    "clean:build": "rm -rf dist",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run"
  },
  "dependencies": {
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "postcss": "^8.5.6",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.0",
    "jsdom": "^25.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}